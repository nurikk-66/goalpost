# Devnet RPC endpoint used by the browser wallet connection.
NEXT_PUBLIC_RPC_URL=https://api.devnet.solana.com

# Where the replay simulator's SSE endpoints are served. instrumentation.ts
# starts it in-process on this port automatically - only override if you're
# running apps/replay separately.
NEXT_PUBLIC_REPLAY_URL=http://localhost:4001
REPLAY_PORT=4001
